{
  "name": "whatsapp-booth",
  "version": "1.0.0",
  "description": "WhatsApp Photobooth Electron App",
  "main": "src/index.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:portable": "electron-builder --win portable"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.712.0",
    "@aws-sdk/s3-request-presigner": "^3.712.0",
    "axios": "^1.7.9",
    "chokidar": "^3.6.0",
    "dotenv": "^16.4.7",
    "electron-squirrel-startup": "^1.0.1",
    "mongodb": "^6.12.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.whatsappbooth.app",
    "productName": "WhatsApp Booth",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**/*",
      "!node_modules/.cache/**/*",
      ".env"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "asar": true
  }
}
